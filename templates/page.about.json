    "collapsible_row_list": {
      "type": "collapsible-row-list",
      "blocks": {
        "faq-1": {
          "type": "item",
          "settings": {
            "expand_by_default": false,
            "icon": "none",
            "title": "How long does it take to receive my order?",
            "text": "<p>Every Efemera piece is made to order by hand in New York City. Please allow 3–4 weeks for production. Once shipped, delivery typically takes 3–5 business days within the US, and 7–14 business days internationally.</p>"
          }
        },
        "faq-2": {
          "type": "item",
          "settings": {
            "expand_by_default": false,
            "icon": "none",
            "title": "What materials do you use?",
            "text": "<p><strong>Echoes Collection:</strong> 14k yellow gold, freshwater pearls, African tourmaline, moonstone, and aquamarine. All stones are ethically sourced.</p><p><strong>Draped in Time Collection:</strong> Sterling silver (925) with hand-painted enamel. Each ring features unique patterns applied by hand — no two are identical.</p>"
          }
        },
        "faq-3": {
          "type": "item",
          "settings": {
            "expand_by_default": false,
            "icon": "none",
            "title": "Do you offer returns or exchanges?",
            "text": "<p>Because each piece is made to order specifically for you, we cannot accept returns. However, if your piece arrives damaged or defective, please contact us within 7 days and we will make it right. Exchanges are available for sizing issues — just email us.</p>"
          }
        },
        "faq-4": {
          "type": "item",
          "settings": {
            "expand_by_default": false,
            "icon": "none",
            "title": "How should I care for my jewelry?",
            "text": "<p><strong>Gold & Pearl pieces:</strong> Store in the provided pouch when not wearing. Avoid contact with perfume, hairspray, and harsh chemicals. Wipe gently with a soft cloth after wearing. Pearls are organic — they love being worn and benefit from the natural oils in your skin.</p><p><strong>Enamel rings:</strong> Enamel is durable but can chip on hard impact. Remove before heavy manual work. Clean with a soft damp cloth. Avoid ultrasonic cleaners.</p>"
          }
        },
        "faq-5": {
          "type": "item",
          "settings": {
            "expand_by_default": false,
            "icon": "none",
            "title": "Do you ship internationally?",
            "text": "<p>Yes. We ship worldwide. International orders may be subject to customs duties and taxes, which are the responsibility of the buyer. All orders are shipped fully insured.</p>"
          }
        },
        "faq-6": {
          "type": "item",
          "settings": {
            "expand_by_default": false,
            "icon": "none",
            "title": "Can I request a custom piece?",
            "text": "<p>We love custom commissions. If you have a vision for a special piece — a unique stone, a personalized design, or a modification to an existing piece — please reach out through our contact page and we'll discuss what's possible.</p>"
          }
        },
        "faq-7": {
          "type": "item",
          "settings": {
            "expand_by_default": false,
            "icon": "none",
            "title": "What sizes are your rings?",
            "text": "<p>Draped in Time rings are adjustable open-band designs that fit most ring sizes (approximately US 5–9). Echoes rings are available in standard US sizes. If you're unsure of your size, we recommend visiting a local jeweler for a professional measurement.</p>"
          }
        },
        "faq-8": {
          "type": "item",
          "settings": {
            "expand_by_default": false,
            "icon": "none",
            "title": "Are your pearls real?",
            "text": "<p>Yes. We use genuine freshwater pearls — solid nacre all the way through, not coated beads. Each pearl is unique in shape, size, and luster. Small natural variations are a sign of authenticity, not imperfection.</p>"
          }
        }
      },
