    "rich_text-4": {
      "type": "rich-text",
      "blocks": {
        "heading": {
          "type": "heading",
          "settings": {
            "title": "The Promise",
            "heading_tag": "h2",
            "heading_font_class": "fs-heading-2-base"
          }
        },
        "text": {
          "type": "text",
          "settings": {
            "text": "<p>We create jewelry that lives alongside your stories. Whether it's the earrings you wore the day you said yes, the ring that makes you smile every time you glance at your hand, or the necklace you never take off — Efemera is designed to be a cherished part of your story, something you carry forward through every chapter of your life.</p><p>Made with natural materials, each piece may have small variations in color and texture, giving it its own character. We see this not as imperfection, but as proof that something real was made by real hands.</p>",
            "text_font_class": "fs-body-100"
          }
        }
      },
