        "heading": {
          "type": "heading",
          "settings": {
            "title": "Efemera was created to capture the quiet, fleeting moments that shape our lives. A laugh, a glance that lingers, a familiar scent — moments that pass in an instant yet leave lasting impressions on the heart.",
